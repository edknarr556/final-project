{
  "name": "@yourOrganization/final-project",
  "version": "0.0.0",
  "description": "Webcomponent final-project following hax / open-wc recommendations",
  "license": "Apache-2.0",
  "author": {
    "name": "Elijah Knarr"
  },
  "type": "module",
  "main": "final-project.js",
  "module": "final-project.js",
  "scripts": {
    "start": "web-dev-server --node-resolve --open --watch",
    "build": "rimraf public && rollup -c rollup.config.js && npm run analyze",
    "analyze": "cem analyze --litelement --exclude public",
    "dddaudit": "hax audit",
    "test": "web-test-runner test/**/*.test.js --coverage --node-resolve",
    "test:watch": "web-test-runner test/**/*.test.js --node-resolve --watch"
  },
  "dependencies": {
    "lit": "^3.2.1",
    "@haxtheweb/d-d-d": "^25.0.0",
    "@haxtheweb/i18n-manager": "^25.0.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.10.4",
    "@open-wc/building-rollup": "^3.0.2",
    "@open-wc/testing": "4.0.0",
    "@web/dev-server": "0.4.6",
    "@web/test-runner": "^0.19.0",
    "rimraf": "^5.0.7",
    "rollup": "^4.0.0"
  }
}